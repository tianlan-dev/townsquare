    "cors": "^2.8.5",
    "cropperjs": "^1.6.2",
    "express": "^4.19.2",
    "glob": "^13.0.0",
    "multer": "^1.4.5-lts.1",
    "openssl": "^2.0.0",
    "path": "^0.12.7",
